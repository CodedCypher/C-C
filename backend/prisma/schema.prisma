// circuit.rocks — commerce + multi-warehouse inventory + multi-branch + light manufacturing
// Branch = where you sell (store/outlet). Warehouse = where stock physically sits.
// Branch<->Warehouse is M:N via BranchWarehouse(priority,isDefault); a central DC can serve many branches.
// Keystone: StockItem is the one stockable identity (Variant 1:1 OR RawMaterial 1:1, XOR app-guarded).
// Per-warehouse quantities live in WarehouseStockItem (onHand/reserved/incoming + reorder).
// StockItem.{onHand,reserved,incoming} are ROLLUPS = SUM across warehouses (kept for global views).
// All physical inventory (Lot, StockLevel, StockMovement, SerialUnit, Bin) is warehouse-scoped.
// Single currency, no FX.

generator client {
  provider     = "prisma-client" // Prisma 7 generator (not prisma-client-js)
  output       = "../src/generated/prisma"
  runtime      = "nodejs" // binaryTargets removed in v7 (JS driver adapters)
  moduleFormat = "cjs" // NestJS compiles to CommonJS
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URL lives in prisma.config.ts (datasource.url), not here.
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
  SUPERADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

enum AddressType {
  SHIPPING
  BILLING
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum StockItemKind {
  VARIANT
  MATERIAL
}

enum SourcingType {
  BUILT
  PURCHASED
}

enum UnitOfMeasure {
  EACH
  METER
  CENTIMETER
  GRAM
  KILOGRAM
  LITER
  MILLILITER
  REEL
  ROLL
  PACK
  SET
}

enum WarehouseType {
  DISTRIBUTION
  RETAIL_BACKROOM
  RETURNS
  GENERAL
}

enum TransferStatus {
  DRAFT
  REQUESTED
  IN_TRANSIT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum SalesChannel {
  WEB
  POS
  PHONE
  MARKETPLACE
}

enum LotStatus {
  ACTIVE
  QUARANTINE
  DEPLETED
}

enum SerialStatus {
  IN_STOCK
  RESERVED
  SOLD
  RETURNED
  SCRAPPED
}

enum MovementReason {
  RECEIPT
  RESERVE
  RELEASE
  SALE
  BUILD_CONSUME
  BUILD_PRODUCE
  TRANSFER_OUT
  TRANSFER_IN
  ADJUST
  RETURN
  SCRAP
}

enum MovementRefType {
  PURCHASE_RECEIPT
  ORDER
  FULFILLMENT
  BUILD_ORDER
  STOCK_TRANSFER
  RETURN
  ADJUSTMENT
}

enum POStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CLOSED
  CANCELLED
}

enum BuildStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PARTIALLY_FULFILLED
  FULFILLED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum FulfillmentType {
  PICKUP
  DELIVERY
}

enum FulfillmentStatus {
  PENDING
  PICKED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  RECEIVED
  COMPLETED
  REJECTED
}

enum ReturnCondition {
  RESELLABLE
  DAMAGED
  DEFECTIVE
  OPENED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum DiscountScope {
  ORDER
  LINE
}

// ─────────────────────────────────────────────────────────────────────────────
// Locations — Branch (sells) + Warehouse (stocks), M:N
// ─────────────────────────────────────────────────────────────────────────────

model Branch {
  id         String    @id @default(cuid())
  name       String
  code       String    @unique
  email      String?
  line1      String?
  line2      String?
  city       String?
  region     String?
  postalCode String?
  country    String?
  phone      String?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  warehouseLinks BranchWarehouse[]
  orders         Order[]
  staff          User[]            @relation("BranchStaffHome")
  staffAccess    BranchStaff[]
}

model Warehouse {
  id           String        @id @default(cuid())
  name         String
  code         String        @unique
  type         WarehouseType @default(GENERAL)
  isDefaultWeb Boolean       @default(false) // default fulfilment WH for WEB orders (app-enforced single true)
  line1        String?
  line2        String?
  city         String?
  region       String?
  postalCode   String?
  country      String?
  phone        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  bins              Bin[]
  branchLinks       BranchWarehouse[]
  stockItems        WarehouseStockItem[]
  lots              Lot[]
  levels            StockLevel[]
  movements         StockMovement[]
  serialUnits       SerialUnit[]
  goodsReceipts     GoodsReceipt[]
  fulfillments      Fulfillment[]
  fulfillmentLines  FulfillmentLine[]
  buildOrders       BuildOrder[]
  buildConsumptions BuildConsumption[]
  buildOutputs      BuildOutput[]
  purchaseOrders    PurchaseOrder[] // destination warehouse
  returnLines       ReturnLine[] // restock destination
  transfersOut      StockTransfer[]      @relation("TransferSource")
  transfersIn       StockTransfer[]      @relation("TransferDest")
}

model BranchWarehouse {
  id          String  @id @default(cuid())
  branchId    String
  warehouseId String
  priority    Int     @default(0)
  isDefault   Boolean @default(false) // the branch's primary source warehouse

  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([branchId, warehouseId])
  @@index([warehouseId])
}

// Per-(stockItem × warehouse) aggregate. available = onHand - reserved.
// onHand == Σ StockMovement.qtyDelta for this (stockItemId, warehouseId) over physical reasons.
model WarehouseStockItem {
  id          String @id @default(cuid())
  stockItemId String
  warehouseId String

  onHand   Decimal @default(0) @db.Decimal(14, 4)
  reserved Decimal @default(0) @db.Decimal(14, 4)
  incoming Decimal @default(0) @db.Decimal(14, 4) // open PO + inbound transfers in transit

  // per-warehouse reorder overrides (fall back to StockItem.* when null)
  reorderPoint Decimal? @db.Decimal(14, 4)
  reorderQty   Decimal? @db.Decimal(14, 4)
  safetyStock  Decimal? @db.Decimal(14, 4)
  binDefaultId String? // preferred put-away bin in this warehouse

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockItem  StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  warehouse  Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  binDefault Bin?      @relation("BinDefaultStock", fields: [binDefaultId], references: [id], onDelete: SetNull)

  @@unique([stockItemId, warehouseId])
  @@index([warehouseId])
}

model StockTransfer {
  id                String         @id @default(cuid())
  transferNumber    String         @unique
  sourceWarehouseId String
  destWarehouseId   String
  status            TransferStatus @default(DRAFT)
  shippedAt         DateTime?
  receivedAt        DateTime?
  createdById       String? // FK to User (audit), no relation by design
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  sourceWarehouse Warehouse           @relation("TransferSource", fields: [sourceWarehouseId], references: [id], onDelete: Restrict)
  destWarehouse   Warehouse           @relation("TransferDest", fields: [destWarehouseId], references: [id], onDelete: Restrict)
  lines           StockTransferLine[]

  @@index([status])
  @@index([sourceWarehouseId])
  @@index([destWarehouseId])
}

model StockTransferLine {
  id              String  @id @default(cuid())
  stockTransferId String
  stockItemId     String
  quantity        Decimal @db.Decimal(14, 4)
  qtyShipped      Decimal @default(0) @db.Decimal(14, 4)
  qtyReceived     Decimal @default(0) @db.Decimal(14, 4)
  sourceLotId     String?
  sourceBinId     String?
  destBinId       String?

  stockTransfer StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  stockItem     StockItem     @relation(fields: [stockItemId], references: [id], onDelete: Restrict)

  @@index([stockTransferId])
  @@index([stockItemId])
}

model BranchStaff {
  id        String    @id @default(cuid())
  branchId  String
  userId    String
  role      UserRole?
  createdAt DateTime  @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([branchId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// A. Identity & auth
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String? // nullable: Google-only users have no password
  googleId        String?    @unique
  role            UserRole   @default(CUSTOMER)
  status          UserStatus @default(ACTIVE)
  firstName       String?
  lastName        String?
  emailVerifiedAt DateTime?
  homeBranchId    String? // staff's home branch
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  homeBranch      Branch?          @relation("BranchStaffHome", fields: [homeBranchId], references: [id], onDelete: SetNull)
  branchAccess    BranchStaff[]
  customerProfile CustomerProfile?
  addresses       Address[]
  sessions        Session[]
  orders          Order[]
  carts           Cart[]
  savedBuilds     SavedBuild[]
  buildChats      BuildChat[]

  @@index([role])
  @@index([homeBranchId])
}

model CustomerProfile {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  phone                    String?
  company                  String?
  defaultShippingAddressId String? // scalar ref to Address (no relation, avoids dup)
  defaultBillingAddressId  String?
  marketingOptIn           Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Address {
  id         String      @id @default(cuid())
  userId     String?
  type       AddressType
  name       String
  line1      String
  line2      String?
  city       String
  region     String
  // Philippine administrative hierarchy (denormalized names + ref codes).
  province     String?
  barangay     String?
  regionCode   String?
  provinceCode String?
  cityCode     String?
  barangayCode String?
  postalCode String
  country    String
  phone      String?
  isDefault  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

/* ------------------------------------------------------------------ *
 * Philippine address reference data (PSGC) — seeded from
 * prisma/dataset/*.json via `pnpm seed:address`. Flat lookup tables
 * linked by the dataset codes; powers the cascading checkout dropdowns.
 * ------------------------------------------------------------------ */

model RefRegion {
  regCode  String @id
  psgcCode String
  regDesc  String
}

model RefProvince {
  provCode String @id
  regCode  String
  psgcCode String
  provDesc String

  @@index([regCode])
}

model RefCityMun {
  citymunCode String @id
  provCode    String
  psgcCode    String
  citymunDesc String

  @@index([provCode])
}

model RefBarangay {
  brgyCode    String @id
  citymunCode String
  provCode    String
  regCode     String
  brgyDesc    String

  @@index([citymunCode])
}

/* Admin-managed payment methods shown at checkout (manual bank / e-wallet). */
model PaymentMethod {
  id           String   @id @default(cuid())
  name         String
  instructions String? // account name / number / notes shown to the buyer
  qrImageUrl   String? // optional QR image (served from /uploads)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payments Payment[]

  @@index([isActive])
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// B. Catalog
// ─────────────────────────────────────────────────────────────────────────────

model Brand {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logoUrl     String?
  website     String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  products Product[]
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  parentId    String?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  parent       Category?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[]        @relation("CategoryTree")
  productLinks ProductCategory[]

  @@index([parentId])
}

model Collection {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  isFeatured  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  productLinks ProductCollection[]
}

model Product {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  description     String?
  status          ProductStatus @default(DRAFT)
  brandId         String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  brand           Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  variants        Variant[]
  images          ProductImage[]
  specs           Spec[]
  optionTypes     OptionType[]
  categoryLinks   ProductCategory[]
  collectionLinks ProductCollection[]

  @@index([brandId])
  @@index([status])
}

model ProductCategory {
  id         String @id @default(cuid())
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
  @@index([categoryId])
}

model ProductCollection {
  id           String @id @default(cuid())
  productId    String
  collectionId String
  position     Int    @default(0)

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([productId, collectionId])
  @@index([collectionId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  variantId String?
  url       String
  alt       String?
  position  Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
}

model Spec {
  id        String  @id @default(cuid())
  productId String
  group     String?
  key       String
  value     String
  unit      String?
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model OptionType {
  id        String @id @default(cuid())
  productId String
  name      String
  position  Int    @default(0)

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  OptionValue[]

  @@unique([productId, name])
}

model OptionValue {
  id           String @id @default(cuid())
  optionTypeId String
  value        String
  position     Int    @default(0)

  optionType   OptionType           @relation(fields: [optionTypeId], references: [id], onDelete: Cascade)
  variantLinks VariantOptionValue[]

  @@unique([optionTypeId, value])
}

model Variant {
  id             String       @id @default(cuid())
  productId      String
  sku            String       @unique
  barcode        String?
  title          String?
  sourcingType   SourcingType @default(PURCHASED)
  price          Decimal      @db.Decimal(12, 2)
  compareAtPrice Decimal?     @db.Decimal(12, 2)
  weightGrams    Int?
  isActive       Boolean      @default(true)
  position       Int          @default(0)
  // ── Project-kit curation (storefront "Build-a-Project") ──────────────────────
  // A BUILT variant becomes a curated kit when isProjectKit=true. kitPublished
  // gates storefront visibility (draft vs live); kitPosition orders the cards.
  isProjectKit   Boolean      @default(false)
  kitPublished   Boolean      @default(false)
  kitPosition    Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  product      Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockItem    StockItem?
  optionValues VariantOptionValue[]
  images       ProductImage[]
  boms         BillOfMaterials[]
  buildOrders  BuildOrder[]
  orderLines   OrderLine[]
  cartLines    CartLine[]
  buildLines   SavedBuildLine[]
  // Back-relation for a raw material published into this sellable variant.
  publishedFromMaterial RawMaterial? @relation("PublishedFromMaterial")

  @@index([productId])
}

model VariantOptionValue {
  id            String @id @default(cuid())
  variantId     String
  optionValueId String

  variant     Variant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue OptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
  @@index([optionValueId])
}

// ─────────────────────────────────────────────────────────────────────────────
// C. Inventory core (unified — everything references StockItem + a Warehouse)
// ─────────────────────────────────────────────────────────────────────────────

model StockItem {
  id            String        @id @default(cuid())
  kind          StockItemKind
  variantId     String?       @unique
  rawMaterialId String?       @unique
  unitOfMeasure UnitOfMeasure @default(EACH)
  trackLot      Boolean       @default(true)
  trackSerial   Boolean       @default(false)

  // ROLLUP buckets = SUM across WarehouseStockItem (kept for global/admin views).
  // available = onHand - reserved.
  onHand   Decimal @default(0) @db.Decimal(14, 4)
  reserved Decimal @default(0) @db.Decimal(14, 4)
  incoming Decimal @default(0) @db.Decimal(14, 4)

  // global reorder fallback (per-warehouse overrides live on WarehouseStockItem)
  reorderPoint Decimal? @db.Decimal(14, 4)
  reorderQty   Decimal? @db.Decimal(14, 4)
  safetyStock  Decimal? @db.Decimal(14, 4)

  // Standard (planning) unit cost in the store currency (PHP, single-currency platform).
  // Cost basis for BOM cost rollups + build consumption/output costing. Null = unknown.
  standardCost Decimal? @db.Decimal(14, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant            Variant?             @relation(fields: [variantId], references: [id], onDelete: Cascade)
  rawMaterial        RawMaterial?         @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  warehouseStock     WarehouseStockItem[]
  levels             StockLevel[]
  lots               Lot[]
  movements          StockMovement[]
  serialUnits        SerialUnit[]
  vendorItems        VendorItem[]
  poLines            PurchaseOrderLine[]
  bomLines           BomLine[]
  buildConsumptions  BuildConsumption[]
  buildOutputs       BuildOutput[]
  receiptLines       GoodsReceiptLine[]
  fulfillmentLines   FulfillmentLine[]
  transferLines      StockTransferLine[]

  @@index([kind])
}

model Bin {
  id          String   @id @default(cuid())
  warehouseId String
  code        String
  zone        String?
  aisle       String?
  shelf       String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse         Warehouse            @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  levels            StockLevel[]
  movements         StockMovement[]
  serialUnits       SerialUnit[]
  receiptLines      GoodsReceiptLine[]
  buildConsumptions BuildConsumption[]
  buildOutputs      BuildOutput[]
  fulfillmentLines  FulfillmentLine[]
  returnLines       ReturnLine[]
  defaultForStock   WarehouseStockItem[] @relation("BinDefaultStock")

  @@unique([warehouseId, code]) // bin codes unique within a warehouse
  @@index([warehouseId])
}

model Lot {
  id            String    @id @default(cuid())
  stockItemId   String
  warehouseId   String
  code          String
  unitCost      Decimal   @db.Decimal(14, 4)
  qtyReceived   Decimal   @db.Decimal(14, 4)
  qtyRemaining  Decimal   @db.Decimal(14, 4)
  mfgDate       DateTime?
  expiry        DateTime?
  status        LotStatus @default(ACTIVE)
  receiptLineId String?   @unique
  sourceLotId   String? // transfer lineage: the source lot this dest lot was created from
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stockItem         StockItem          @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  warehouse         Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  receiptLine       GoodsReceiptLine?  @relation(fields: [receiptLineId], references: [id], onDelete: SetNull)
  sourceLot         Lot?               @relation("LotLineage", fields: [sourceLotId], references: [id], onDelete: SetNull)
  childLots         Lot[]              @relation("LotLineage")
  levels            StockLevel[]
  movements         StockMovement[]
  serialUnits       SerialUnit[]
  buildConsumptions BuildConsumption[]
  buildOutputs      BuildOutput[]
  fulfillmentLines  FulfillmentLine[]
  returnLines       ReturnLine[]

  @@index([stockItemId, warehouseId, status])
  @@index([stockItemId, warehouseId, createdAt]) // FIFO order; FEFO via expiry
  @@index([warehouseId])
}

model StockLevel {
  id          String  @id @default(cuid())
  stockItemId String
  warehouseId String
  lotId       String?
  binId       String?
  onHand      Decimal @default(0) @db.Decimal(14, 4)
  reserved    Decimal @default(0) @db.Decimal(14, 4)

  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  lot       Lot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)
  bin       Bin?      @relation(fields: [binId], references: [id], onDelete: SetNull)

  @@unique([stockItemId, warehouseId, lotId, binId])
  @@index([stockItemId, warehouseId])
  @@index([warehouseId])
}

model StockMovement {
  id             String           @id @default(cuid())
  stockItemId    String
  warehouseId    String
  lotId          String?
  binId          String?
  serialUnitId   String?
  qtyDelta       Decimal          @db.Decimal(14, 4) // signed
  reason         MovementReason
  refType        MovementRefType?
  refId          String?
  unitCostAtMove Decimal?         @db.Decimal(14, 4)
  note           String?
  createdById    String? // FK to User (audit), no relation by design
  createdAt      DateTime         @default(now()) // immutable: no updatedAt

  stockItem  StockItem   @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  warehouse  Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  lot        Lot?        @relation(fields: [lotId], references: [id], onDelete: SetNull)
  bin        Bin?        @relation(fields: [binId], references: [id], onDelete: SetNull)
  serialUnit SerialUnit? @relation(fields: [serialUnitId], references: [id], onDelete: SetNull)

  @@index([stockItemId, warehouseId, createdAt]) // per-warehouse ledger reconciliation
  @@index([refType, refId])
  @@index([warehouseId])
}

model SerialUnit {
  id            String       @id @default(cuid())
  serial        String       @unique
  stockItemId   String
  warehouseId   String? // current location; null when SOLD / in transit
  lotId         String?
  binId         String?
  status        SerialStatus @default(IN_STOCK)
  orderLineId   String?
  buildOutputId String?
  returnLineId  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  stockItem        StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  warehouse        Warehouse?        @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  lot              Lot?              @relation(fields: [lotId], references: [id], onDelete: SetNull)
  bin              Bin?              @relation(fields: [binId], references: [id], onDelete: SetNull)
  orderLine        OrderLine?        @relation(fields: [orderLineId], references: [id], onDelete: SetNull)
  buildOutput      BuildOutput?      @relation(fields: [buildOutputId], references: [id], onDelete: SetNull)
  returnLine       ReturnLine?       @relation(fields: [returnLineId], references: [id], onDelete: SetNull)
  movements        StockMovement[]
  fulfillmentLines FulfillmentLine[]

  @@index([stockItemId, status])
  @@index([warehouseId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// D. Manufacturing (BUILT variants)
// ─────────────────────────────────────────────────────────────────────────────

model RawMaterial {
  id          String        @id @default(cuid())
  name        String
  sku         String        @unique
  description String?
  defaultUnit UnitOfMeasure @default(EACH)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  // Set when this material has been published as a sellable storefront product.
  // The published Variant keeps its OWN stock pool (StockItem.kind = VARIANT);
  // this link only records provenance + blocks double-publishing.
  publishedVariantId String?  @unique
  publishedVariant   Variant? @relation("PublishedFromMaterial", fields: [publishedVariantId], references: [id], onDelete: SetNull)

  stockItem StockItem? // 1:1 (StockItem holds rawMaterialId)
}

model BillOfMaterials {
  id        String   @id @default(cuid())
  variantId String
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant     Variant      @relation(fields: [variantId], references: [id], onDelete: Cascade)
  lines       BomLine[]
  buildOrders BuildOrder[]

  @@unique([variantId, version])
}

model BomLine {
  id          String        @id @default(cuid())
  bomId       String
  stockItemId String // input (a raw material's StockItem; generic to allow sub-assembly)
  quantity    Decimal       @db.Decimal(14, 4)
  unit        UnitOfMeasure
  scrapPct    Decimal?      @db.Decimal(7, 4)

  bom       BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)
  stockItem StockItem       @relation(fields: [stockItemId], references: [id], onDelete: Restrict)

  @@index([bomId])
  @@index([stockItemId])
}

model BuildOrder {
  id          String      @id @default(cuid())
  variantId   String // output product
  bomId       String
  warehouseId String // where the build runs (consumes + produces)
  status      BuildStatus @default(DRAFT)
  qtyPlanned  Decimal     @db.Decimal(14, 4)
  qtyProduced Decimal     @default(0) @db.Decimal(14, 4)
  startedAt   DateTime?
  completedAt DateTime?
  createdById String? // FK to User (audit), no relation by design
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  variant      Variant            @relation(fields: [variantId], references: [id], onDelete: Restrict)
  bom          BillOfMaterials    @relation(fields: [bomId], references: [id], onDelete: Restrict)
  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  consumptions BuildConsumption[]
  outputs      BuildOutput[]

  @@index([status])
  @@index([warehouseId])
}

model BuildConsumption {
  id                String   @id @default(cuid())
  buildOrderId      String
  stockItemId       String
  warehouseId       String
  lotId             String?
  binId             String?
  quantity          Decimal  @db.Decimal(14, 4)
  unitCostAtConsume Decimal? @db.Decimal(14, 4)
  createdAt         DateTime @default(now())

  buildOrder BuildOrder @relation(fields: [buildOrderId], references: [id], onDelete: Cascade)
  stockItem  StockItem  @relation(fields: [stockItemId], references: [id], onDelete: Restrict)
  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lot        Lot?       @relation(fields: [lotId], references: [id], onDelete: SetNull)
  bin        Bin?       @relation(fields: [binId], references: [id], onDelete: SetNull)

  @@index([buildOrderId])
  @@index([stockItemId])
}

model BuildOutput {
  id               String   @id @default(cuid())
  buildOrderId     String
  stockItemId      String // the variant's StockItem (finished good)
  warehouseId      String
  lotId            String // new finished-good lot
  binId            String?
  quantity         Decimal  @db.Decimal(14, 4)
  computedUnitCost Decimal  @db.Decimal(14, 4) // rolled from consumptions
  createdAt        DateTime @default(now())

  buildOrder  BuildOrder   @relation(fields: [buildOrderId], references: [id], onDelete: Cascade)
  stockItem   StockItem    @relation(fields: [stockItemId], references: [id], onDelete: Restrict)
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lot         Lot          @relation(fields: [lotId], references: [id], onDelete: Restrict)
  bin         Bin?         @relation(fields: [binId], references: [id], onDelete: SetNull)
  serialUnits SerialUnit[]

  @@index([buildOrderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// E. Procurement (vendors, PO, receiving)
// ─────────────────────────────────────────────────────────────────────────────

model Vendor {
  id           String    @id @default(cuid())
  name         String
  code         String    @unique
  email        String?
  phone        String?
  address      String?
  leadTimeDays Int?
  isActive     Boolean   @default(true)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  items          VendorItem[]
  purchaseOrders PurchaseOrder[]
}

model VendorItem {
  id           String   @id @default(cuid())
  vendorId     String
  stockItemId  String
  vendorSku    String?
  unitCost     Decimal  @db.Decimal(14, 4)
  currency     String   @default("PHP")
  moq          Decimal? @db.Decimal(14, 4)
  packSize     Decimal? @db.Decimal(14, 4)
  leadTimeDays Int?
  isPreferred  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendor    Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@unique([vendorId, stockItemId])
  @@index([stockItemId])
}

model PurchaseOrder {
  id                   String    @id @default(cuid())
  vendorId             String
  destinationWarehouseId String? // default receiving warehouse
  poNumber             String    @unique
  status               POStatus  @default(DRAFT)
  currency             String    @default("PHP")
  expectedDate         DateTime?
  subtotal             Decimal   @default(0) @db.Decimal(14, 2)
  shippingCost         Decimal   @default(0) @db.Decimal(14, 2)
  taxTotal             Decimal   @default(0) @db.Decimal(14, 2)
  total                Decimal   @default(0) @db.Decimal(14, 2)
  notes                String?
  createdById          String? // FK to User (audit), no relation by design
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  vendor               Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  destinationWarehouse Warehouse?          @relation(fields: [destinationWarehouseId], references: [id], onDelete: SetNull)
  lines                PurchaseOrderLine[]
  receipts             GoodsReceipt[]

  @@index([vendorId])
  @@index([status])
  @@index([destinationWarehouseId])
}

model PurchaseOrderLine {
  id              String  @id @default(cuid())
  purchaseOrderId String
  stockItemId     String // purchasable: raw material OR PURCHASED variant (app guard)
  description     String
  qtyOrdered      Decimal @db.Decimal(14, 4)
  qtyReceived     Decimal @default(0) @db.Decimal(14, 4)
  unitCost        Decimal @db.Decimal(14, 4)
  lineTotal       Decimal @db.Decimal(14, 2)

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  stockItem     StockItem          @relation(fields: [stockItemId], references: [id], onDelete: Restrict)
  receiptLines  GoodsReceiptLine[]

  @@index([purchaseOrderId])
  @@index([stockItemId])
}

model GoodsReceipt {
  id              String   @id @default(cuid())
  purchaseOrderId String
  warehouseId     String // the receiving warehouse
  receivedAt      DateTime @default(now())
  referenceNo     String?
  receivedById    String? // FK to User (audit), no relation by design
  createdAt       DateTime @default(now())

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  warehouse     Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lines         GoodsReceiptLine[]

  @@index([purchaseOrderId])
  @@index([warehouseId])
}

model GoodsReceiptLine {
  id                  String    @id @default(cuid())
  goodsReceiptId      String
  purchaseOrderLineId String
  stockItemId         String
  qtyReceived         Decimal   @db.Decimal(14, 4)
  unitCost            Decimal   @db.Decimal(14, 4)
  binId               String? // put-away location (within the receipt's warehouse)
  lotCode             String?
  mfgDate             DateTime?
  expiry              DateTime?

  goodsReceipt      GoodsReceipt      @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  purchaseOrderLine PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Restrict)
  stockItem         StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Restrict)
  bin               Bin?              @relation(fields: [binId], references: [id], onDelete: SetNull)
  lot               Lot? // the lot created from this receipt line (Lot.receiptLineId)

  @@index([goodsReceiptId])
  @@index([purchaseOrderLineId])
}

// ─────────────────────────────────────────────────────────────────────────────
// F. Commerce — cart, order, payment, fulfillment, returns
// ─────────────────────────────────────────────────────────────────────────────

model Cart {
  id           String     @id @default(cuid())
  userId       String?
  sessionToken String?    @unique
  status       CartStatus @default(ACTIVE)
  currency     String     @default("PHP")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  lines CartLine[]

  @@index([userId])
}

model CartLine {
  id                String  @id @default(cuid())
  cartId            String
  variantId         String
  quantity          Int
  unitPriceSnapshot Decimal @db.Decimal(12, 2)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([cartId, variantId])
  @@index([variantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Saved builds — a maker's inspiration (pasted list / URL / photo) resolved into
// catalog variants. Deliberately NOT a BUILT-variant+BOM: those are sellable
// catalog products; a guest's one-off build must never pollute the catalog.
// Lines reference existing component variants (null = no confident match).
// ─────────────────────────────────────────────────────────────────────────────

enum BuildSource {
  TEXT
  URL
  IMAGE
}

/// Conversation "personality" for the build-assistant chat (see BuildChat).
enum BuildChatMode {
  BRAINSTORM
  GRILL
  IMPECCABLE
}

enum BuildChatRole {
  USER
  ASSISTANT
}

model SavedBuild {
  id           String      @id @default(cuid())
  title        String
  sourceType   BuildSource @default(TEXT)
  sourceRef    String? // original pasted text / url (truncated)
  sessionToken String? // guest cr_cart token that owns this build
  userId       String? // stamped when the maker is signed in
  createdAt    DateTime    @default(now())

  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  lines        SavedBuildLine[]
  chatMessages BuildChatMessage[] // assistant turns that resolved into this build

  @@index([sessionToken])
  @@index([userId])
}

model SavedBuildLine {
  id         String  @id @default(cuid())
  buildId    String
  variantId  String? // null = matcher found no confident match (unmatched line)
  rawLabel             String // what the source called this part
  quantity             Int      @default(1)
  confidence           Float    @default(0) // matcher confidence 0..1
  note                 String? // substitution / clarification note from the matcher
  position             Int      @default(0)
  alternativeVariantIds String[] @default([]) // ranked functional-equivalent variant ids

  build   SavedBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
  variant Variant?   @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([buildId])
  @@index([variantId])
}

/// A persisted build-assistant conversation. Ownership mirrors SavedBuild:
/// a guest owns by the `cr_cart` sessionToken, a signed-in maker by userId.
model BuildChat {
  id           String        @id @default(cuid())
  title        String        @default("New build chat")
  mode         BuildChatMode @default(BRAINSTORM)
  sessionToken String? // guest cr_cart token that owns this chat
  userId       String? // stamped when the maker is signed in
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user     User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages BuildChatMessage[]

  @@index([sessionToken])
  @@index([userId])
}

/// One turn in a BuildChat. An assistant turn that resolved a parts list carries
/// `buildId`, which the frontend renders as an inline resolved-build card.
model BuildChatMessage {
  id        String        @id @default(cuid())
  chatId    String
  role      BuildChatRole
  content   String // the message text
  imageUrl  String? // root-relative URL of an attached build-from-photo image
  buildId   String? // set when this assistant turn resolved a SavedBuild
  createdAt DateTime      @default(now())

  chat  BuildChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  build SavedBuild? @relation(fields: [buildId], references: [id], onDelete: SetNull)

  @@index([chatId])
  @@index([buildId])
}

model Order {
  id          String       @id @default(cuid())
  orderNumber String       @unique
  userId      String? // null = guest
  branchId    String? // null = web/online channel
  channel     SalesChannel @default(WEB)
  fulfillmentType FulfillmentType @default(DELIVERY)
  email       String
  status      OrderStatus  @default(PENDING)
  currency    String       @default("PHP")

  // shipping address snapshot (denormalized for history)
  shipName     String?
  shipLine1    String?
  shipLine2    String?
  shipBarangay String?
  shipCity     String?
  shipProvince String?
  shipRegion   String?
  shipPostal   String?
  shipCountry  String?
  shipPhone    String?

  // billing address snapshot
  billName    String?
  billLine1   String?
  billLine2   String?
  billCity    String?
  billRegion  String?
  billPostal  String?
  billCountry String?
  billPhone   String?

  subtotal      Decimal @default(0) @db.Decimal(12, 2)
  discountTotal Decimal @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal @default(0) @db.Decimal(12, 2)
  shippingTotal Decimal @default(0) @db.Decimal(12, 2)
  grandTotal    Decimal @default(0) @db.Decimal(12, 2)

  shippingMethodId String?
  placedAt         DateTime?
  confirmedAt      DateTime?
  cancelledAt      DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  branch         Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  shippingMethod ShippingMethod? @relation(fields: [shippingMethodId], references: [id], onDelete: SetNull)
  lines          OrderLine[]
  payments       Payment[]
  fulfillments   Fulfillment[]
  discounts      OrderDiscount[]
  returns        ReturnRequest[]

  @@index([userId])
  @@index([status])
  @@index([branchId])
  @@index([channel])
}

model OrderLine {
  id             String  @id @default(cuid())
  orderId        String
  variantId      String
  sku            String // snapshot
  title          String // snapshot
  quantity       Int
  unitPrice      Decimal @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  taxRate        Decimal @default(0) @db.Decimal(7, 4)
  taxAmount      Decimal @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal @db.Decimal(12, 2)
  qtyFulfilled   Int     @default(0)
  qtyReturned    Int     @default(0)

  order            Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant          Variant           @relation(fields: [variantId], references: [id], onDelete: Restrict)
  fulfillmentLines FulfillmentLine[]
  returnLines      ReturnLine[]
  serialUnits      SerialUnit[]

  @@index([orderId])
  @@index([variantId])
}

model ShippingMethod {
  id       String   @id @default(cuid())
  name     String
  carrier  String?
  price    Decimal  @db.Decimal(12, 2)
  freeOver Decimal? @db.Decimal(12, 2)
  minDays  Int?
  maxDays  Int?
  isActive Boolean  @default(true)

  orders Order[]
}

model Discount {
  id               String        @id @default(cuid())
  code             String        @unique
  type             DiscountType
  value            Decimal       @db.Decimal(12, 2)
  scope            DiscountScope @default(ORDER)
  minSubtotal      Decimal?      @db.Decimal(12, 2)
  usageLimit       Int?
  perCustomerLimit Int?
  timesUsed        Int           @default(0)
  startsAt         DateTime?
  endsAt           DateTime?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  orderLinks OrderDiscount[]
}

model OrderDiscount {
  id         String  @id @default(cuid())
  orderId    String
  discountId String?
  code       String
  amount     Decimal @db.Decimal(12, 2)

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  discount Discount? @relation(fields: [discountId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  provider          String
  providerPaymentId String?
  status            PaymentStatus @default(PENDING)
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("PHP")
  capturedAt        DateTime?
  failureReason     String?
  proofImageUrl     String? // manual-payment proof image (served from /uploads)
  reference         String? // manual-payment reference / admin note
  verifiedAt        DateTime? // when an admin verified the manual proof
  paymentMethodId   String? // admin-managed PaymentMethod chosen at checkout
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  refunds       Refund[]

  @@index([orderId])
  @@index([paymentMethodId])
}

model Refund {
  id               String        @id @default(cuid())
  paymentId        String
  returnRequestId  String?
  amount           Decimal       @db.Decimal(12, 2)
  reason           String?
  status           PaymentStatus @default(PENDING)
  providerRefundId String?
  processedAt      DateTime?
  createdAt        DateTime      @default(now())

  payment       Payment        @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  returnRequest ReturnRequest? @relation(fields: [returnRequestId], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@index([returnRequestId])
}

model Fulfillment {
  id             String            @id @default(cuid())
  orderId        String
  warehouseId    String // the shipping warehouse (stock source)
  status         FulfillmentStatus @default(PENDING)
  carrier        String?
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  warehouse Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lines     FulfillmentLine[]

  @@index([orderId])
  @@index([warehouseId])
}

model FulfillmentLine {
  id            String  @id @default(cuid())
  fulfillmentId String
  orderLineId   String
  stockItemId   String
  warehouseId   String // source warehouse the line is picked from
  lotId         String?
  binId         String?
  serialUnitId  String?
  quantity      Int

  fulfillment Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  orderLine   OrderLine   @relation(fields: [orderLineId], references: [id], onDelete: Restrict)
  stockItem   StockItem   @relation(fields: [stockItemId], references: [id], onDelete: Restrict)
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lot         Lot?        @relation(fields: [lotId], references: [id], onDelete: SetNull)
  bin         Bin?        @relation(fields: [binId], references: [id], onDelete: SetNull)
  serialUnit  SerialUnit? @relation(fields: [serialUnitId], references: [id], onDelete: SetNull)

  @@index([fulfillmentId])
  @@index([orderLineId])
}

model ReturnRequest {
  id          String       @id @default(cuid())
  orderId     String
  status      ReturnStatus @default(REQUESTED)
  reason      String?
  receivedAt  DateTime?
  createdById String? // FK to User (audit), no relation by design
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  order   Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lines   ReturnLine[]
  refunds Refund[]

  @@index([orderId])
}

model ReturnLine {
  id                String          @id @default(cuid())
  returnRequestId   String
  orderLineId       String
  quantity          Int
  condition         ReturnCondition
  restock           Boolean         @default(false)
  restockWarehouseId String? // restock destination warehouse
  restockBinId      String?
  restockLotId      String?

  returnRequest    ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderLine        OrderLine     @relation(fields: [orderLineId], references: [id], onDelete: Restrict)
  restockWarehouse Warehouse?    @relation(fields: [restockWarehouseId], references: [id], onDelete: SetNull)
  restockBin       Bin?          @relation(fields: [restockBinId], references: [id], onDelete: SetNull)
  restockLot       Lot?          @relation(fields: [restockLotId], references: [id], onDelete: SetNull)
  serialUnits      SerialUnit[]

  @@index([returnRequestId])
  @@index([orderLineId])
}

// ─────────────────────────────────────────────────────────────────────────────
// G. Settings (singleton)
// ─────────────────────────────────────────────────────────────────────────────

model StoreSetting {
  id                       String   @id @default(cuid())
  currency                 String   @default("PHP")
  taxInclusive             Boolean  @default(false)
  lowStockThresholdDefault Decimal? @db.Decimal(14, 4)
  defaultWarehouseId       String? // fallback fulfilment warehouse
  defaultBranchId          String? // fallback branch
  nextOrderSeq             Int      @default(1000)
  nextPoSeq                Int      @default(1000)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}
