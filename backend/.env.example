DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/circuit_rocks?schema=public"
# Required by prisma.config.ts for `prisma migrate dev` / `migrate diff` (shadow DB).
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/circuit_rocks_shadow?schema=public"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret used to sign 15-minute access JWTs. Generate a 64-char hex value, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=

# Google OAuth 2.0 (see SETUP.md). App boots without these; Google login errors
# at runtime until they are filled in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Where the browser is redirected after Google login + used as the CORS origin.
FRONTEND_URL=http://localhost:5173

# ── Build matcher (paste-inspiration → catalog parts) ─────────────────────────
# BuildMatcherService tries Groq first, then falls back to Gemini. Configure at
# least one; if neither is set the /storefront/builds/resolve endpoint 503s.
#
# Groq (PRIMARY) — free, fast, OpenAI-compatible. Key: https://console.groq.com
GROQ_API_KEY=
# Optional model override (default: llama-3.3-70b-versatile).
# GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (FALLBACK) — used only when Groq is unset or its retries are exhausted.
GEMINI_API_KEY=
